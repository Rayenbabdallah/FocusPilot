# ── AWS Bedrock credentials (leave blank to run in DEMO MODE) ──────────────
# In demo mode all AI responses are realistic pre-built examples so you can
# test every feature without an AWS account.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── Bedrock model IDs ───────────────────────────────────────────────────────
BEDROCK_MODEL_PRO=amazon.nova-pro-v1:0
BEDROCK_MODEL_LITE=amazon.nova-lite-v1:0
BEDROCK_MODEL_MICRO=amazon.nova-micro-v1:0

# ── Database & uploads ──────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./focuspilot.db
UPLOAD_DIR=./uploads

# ── Optional: force demo mode even if credentials are present ───────────────
# DEMO_MODE=true
